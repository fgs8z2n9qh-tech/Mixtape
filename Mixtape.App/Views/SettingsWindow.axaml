<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Mixtape.App.Views.SettingsWindow"
        Title="Settings" Width="460" Height="300"
        Background="{StaticResource AppBrush}" Foreground="{StaticResource TextBrush}"
        FontFamily="Inter" CanResize="False" WindowStartupLocation="CenterOwner">
  <StackPanel Margin="26" Spacing="14">
    <TextBlock Text="Settings" FontSize="20" FontWeight="Bold"/>
    <TextBlock Text="ACCENT COLOUR" FontSize="11" FontWeight="Bold" Foreground="{StaticResource SubtleBrush}" Margin="0,6,0,0"/>
    <WrapPanel x:Name="AccentPanel" Orientation="Horizontal"/>
    <TextBlock Text="THEME" FontSize="11" FontWeight="Bold" Foreground="{StaticResource SubtleBrush}" Margin="0,8,0,0"/>
    <StackPanel x:Name="VariantPanel" Orientation="Horizontal" Spacing="8"/>
    <Button Content="Done" Click="OnDone" HorizontalAlignment="Right" Margin="0,10,0,0"/>
  </StackPanel>
</Window>
